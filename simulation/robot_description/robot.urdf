<?xml version="1.0"?>
<!--
  RoboCupRescue RMRC 2026 — Gazebo simulation URDF
  Diff-drive box robot: 0.27m x 0.25m x 0.15m body
  LiDAR: 360°, 20m range (Unitree L2 equivalent)
  Cameras: front, arm, backward (640x480 @ 15 FPS)
-->
<robot name="rescue_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ==================== Materials ==================== -->
  <material name="dark_gray">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.05 0.05 0.05 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.0 0.3 0.6 1.0"/>
  </material>

  <!-- ==================== Base Link ==================== -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.27 0.25 0.15"/>
      </geometry>
      <origin xyz="0 0 0.075"/>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.27 0.25 0.15"/>
      </geometry>
      <origin xyz="0 0 0.075"/>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0 0 0.075"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.025" iyz="0" izz="0.015"/>
    </inertial>
  </link>

  <!-- ==================== Wheels ==================== -->
  <!-- Left wheel -->
  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.03"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.04" length="0.03"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0002"/>
    </inertial>
  </link>
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.14 0.04" rpy="${-pi/2} 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Right wheel -->
  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.03"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.04" length="0.03"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0002"/>
    </inertial>
  </link>
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.14 0.04" rpy="${-pi/2} 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Front caster -->
  <link name="front_caster">
    <visual>
      <geometry><sphere radius="0.02"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry><sphere radius="0.02"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>
  <joint name="front_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_caster"/>
    <origin xyz="0.11 0 0.02"/>
  </joint>

  <!-- ==================== LiDAR ==================== -->
  <link name="lidar_link">
    <visual>
      <geometry><cylinder radius="0.03" length="0.04"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.03" length="0.04"/></geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 0.17" rpy="0 0 0"/>
  </joint>

  <!-- ==================== Camera Links ==================== -->
  <link name="front_camera_link"/>
  <joint name="front_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_camera_link"/>
    <origin xyz="0.135 0 0.12" rpy="0 0 0"/>
  </joint>

  <link name="arm_camera_link"/>
  <joint name="arm_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_camera_link"/>
    <origin xyz="0.10 0 0.18" rpy="0 0.3 0"/>
  </joint>

  <link name="backward_camera_link"/>
  <joint name="backward_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="backward_camera_link"/>
    <origin xyz="-0.135 0 0.12" rpy="0 0 ${pi}"/>
  </joint>

  <!-- ==================== Gazebo Plugins ==================== -->

  <!-- Diff drive -->
  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <namespace>/</namespace>
      </ros>
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.28</wheel_separation>
      <wheel_diameter>0.08</wheel_diameter>
      <max_wheel_torque>5.0</max_wheel_torque>
      <max_wheel_acceleration>2.0</max_wheel_acceleration>
      <command_topic>cmd_vel</command_topic>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
      <update_rate>50.0</update_rate>
    </plugin>
  </gazebo>

  <!-- LiDAR (360° laser scan — Unitree L2 equivalent) -->
  <gazebo reference="lidar_link">
    <sensor name="lidar" type="ray">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>20.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin name="lidar_plugin" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <namespace>/</namespace>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- Front camera -->
  <gazebo reference="front_camera_link">
    <sensor name="front_camera" type="camera">
      <always_on>true</always_on>
      <update_rate>15</update_rate>
      <camera>
        <horizontal_fov>1.2</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>50</far>
        </clip>
      </camera>
      <plugin name="front_cam_plugin" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>/</namespace>
          <remapping>~/image_raw:=camera/front/image_raw</remapping>
        </ros>
        <frame_name>front_camera_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- Arm camera -->
  <gazebo reference="arm_camera_link">
    <sensor name="arm_camera" type="camera">
      <always_on>true</always_on>
      <update_rate>15</update_rate>
      <camera>
        <horizontal_fov>1.2</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>50</far>
        </clip>
      </camera>
      <plugin name="arm_cam_plugin" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>/</namespace>
          <remapping>~/image_raw:=camera/arm/image_raw</remapping>
        </ros>
        <frame_name>arm_camera_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

</robot>
