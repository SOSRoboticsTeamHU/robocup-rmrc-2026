# RoboCup Rescue RMRC 2026 - Environment Example
# Copy to .env and adjust for your setup (do not commit .env)

# Network (Ethernet tether between laptop and Jetson)
JETSON_IP=192.168.2.100
LAPTOP_IP=192.168.2.101

# Camera device IDs (comma-separated: front,arm,backward)
# Use v4l2-ctl --list-devices to find /dev/video*
# CAMERA_DEVICES=0,2,4

# Vision (Jetson)
# VISION_FORCE_OPENCV=0        # 1 = use OpenCV for all cameras (no GPU)
# VISION_MAX_GPU_CAMERAS=3    # Max Full GPU pipelines (default 3)

# Vision node vs DeepStream
# USE_DEEPSTREAM_SDK=0        # 1 = use DeepStream vision pipeline
# USE_VISION_NODE=1

# RViz stream on Jetson
# USE_RVIZ_ON_JETSON=1

# Simulation / Nav2
# USE_SIM=0
# USE_NAV2=0

# LeRobot leader arm (optional)
# LEROBOT_SRC=/path/to/lerobot/src
